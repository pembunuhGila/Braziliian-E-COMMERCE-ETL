    <connection>con_olist_resources</connection>
    <sql>SELECT
    c.customer_id,
    o.order_id,
    oi.order_item_id,
    oi.product_id,

    oi.seller_id,
    s.seller_zip_code_prefix,
    s.seller_city,
    s.seller_state,

    oi.price,
    oi.freight_value,
    (oi.price + oi.freight_value) AS total_amount,

    CAST(DATE(o.order_purchase_timestamp) AS DATE) AS full_date,
    HOUR(o.order_purchase_timestamp) AS hour,
    MINUTE(o.order_purchase_timestamp) AS minute,
    SECOND(o.order_purchase_timestamp) AS second

FROM olist_orders_dataset o
JOIN olist_customers_dataset c
    ON o.customer_id = c.customer_id
JOIN olist_order_items_dataset oi
    ON o.order_id = oi.order_id
JOIN olist_sellers_dataset s
    ON oi.seller_id = s.seller_id

LIMIT 100;</sql>
