    <connection>con_olist_resources</connection>
    <sql>SELECT
    DATE(order_purchase_timestamp) AS full_date,
    DAY(order_purchase_timestamp) AS day,
    MONTH(order_purchase_timestamp) AS month,
    YEAR(order_purchase_timestamp) AS year,
    HOUR(order_purchase_timestamp) AS hour,
    MINUTE(order_purchase_timestamp) AS minute,
    SECOND(order_purchase_timestamp) AS second
FROM olist_orders_dataset
WHERE order_purchase_timestamp IS NOT NULL;</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
